{
	"name": "the-great-estimation",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "prisma generate && prisma db push && next dev",
		"build": "prisma generate && prisma migrate deploy && next build",
		"start": "next start",
		"lint": "NODE_NO_WARNINGS=1 eslint .",
		"lint:fix": "NODE_NO_WARNINGS=1 eslint . --fix",
		"format": "prettier --write .",
		"db:push": "prisma db push",
		"db:seed": "tsx --env-file=.env prisma/seed.ts",
		"db:seed:prod": "tsx --env-file=.env.production prisma/seed.ts",
		"db:reset": "prisma migrate reset --force && pnpm migrate:dev"
	},
	"dependencies": {
