		"exceljs": "^4.4.0",
		"luxon": "^3.7.2",
		"next": "16.1.7",
		"papaparse": "^5.5.3",
		"pg": "^8.20.0",
		"postgres": "^3.4.8",
		"radix-ui": "^1.4.3",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"tailwindcss": "^4.2.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
