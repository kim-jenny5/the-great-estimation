		"autoprefixer": "^10.4.27",
		"dotenv": "^17.3.1",
		"eslint": "^9.39.4",
		"eslint-config-next": "15.4.5",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
